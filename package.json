{
  "name": "brunt-cli",
  "version": "0.4.0",
  "description": "Adversarial AI code review. Finds bugs, generates failing tests as proof.",
  "license": "MIT",
  "type": "module",
  "author": "anfocic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anfocic/brunt.git"
  },
  "homepage": "https://github.com/anfocic/brunt",
  "bugs": {
    "url": "https://github.com/anfocic/brunt/issues"
  },
  "bin": {
    "brunt": "dist/cli.js"
  },
  "files": [
    "dist",
    "action",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "code-review",
    "ai",
    "security",
    "testing",
    "cli",
    "adversarial",
    "static-analysis",
    "llm",
    "code-quality",
    "github-actions"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target node --outdir dist --format esm",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22"
  }
}
