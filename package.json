{
  "name": "brunt",
  "version": "0.2.0",
  "description": "Adversarial AI code review. Finds bugs, generates failing tests as proof.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "brunt": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "code-review",
    "ai",
    "security",
    "testing",
    "cli",
    "adversarial",
    "static-analysis"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target node --outdir dist --format esm",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22"
  }
}
