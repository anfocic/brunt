{
  "name": "vigil-review",
  "version": "0.1.0",
  "description": "Adversarial AI code review. Finds bugs, generates failing tests as proof.",
  "type": "module",
  "bin": {
    "vigil": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --outfile dist/vigil src/cli.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
